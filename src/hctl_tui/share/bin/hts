#!/bin/zsh
# hts — hctl-tui entrypoint
emulate -L zsh
set -euo pipefail
# Inherited xtrace/verbose (e.g. from a parent shell) would paint "choice=..." / "hdr=..."
# into the TUI on every assignment — never want that in the interactive UI.
unsetopt xtrace verbose 2>/dev/null || true

# ---------------------------------------------------------------------------
# PATH bootstrap (MUST be first real work)
#
# `uv tool run` / GUI launches often inherit a PATH that omits /bin and
# /usr/bin entirely. That makes bare `rm`, `mktemp`, `cat`, etc. fail with
# "command not found" even though the binaries exist. Always put system +
# uv-tool bins at the front. (${PATH:-default} does NOT treat PATH="" as unset.)
# ---------------------------------------------------------------------------
_hts_sys="/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin:/usr/local/bin"
_hts_user=""
[[ -n "${HOME:-}" && -d "$HOME/.local/bin" ]] && _hts_user="$HOME/.local/bin"
[[ -n "${HOME:-}" && -d "$HOME/.cargo/bin" ]] && _hts_user="${_hts_user:+$_hts_user:}$HOME/.cargo/bin"
export PATH="${_hts_user:+$_hts_user:}${_hts_sys}${PATH:+:$PATH}"
unset _hts_sys _hts_user

# HTS_ROOT / HTS_LIB may be injected by the Python uv entrypoint or local bin/hts.
: "${HTS_ROOT:=$(cd -- "${0:A:h}/.." && pwd)}"
: "${HTS_LIB:=$HTS_ROOT/lib}"

source "$HTS_LIB/core.sh"
source "$HTS_LIB/deps.sh"
source "$HTS_LIB/profiles.sh"
source "$HTS_LIB/pipelines.sh"
source "$HTS_LIB/runner.sh"
source "$HTS_LIB/transfer.sh"
source "$HTS_LIB/tui.sh"

# Re-assert PATH after libs (mkdir user bin + de-dupe)
hts_ensure_path

hts_usage() {
  /bin/cat <<'EOF'
hts — Harness test-suite orchestration

Usage:
  hts
      Interactive TUI (TTY)
  hts help
  hts init [--profile NAME] [--skip-deps]
      First-run: deps + config + hctl auth
  hts doctor [--fix-deps]
      Show local config / install peer tools
  hts run [options]
      Fire or dry-run a matrix
  hts profile list|use NAME|init [NAME]
  hts matrix list|add|edit|remove [options]
  hts export [--out DIR] [--profile NAME|all] [--include-secrets] [--no-config]
  hts import PATH [--as NAME] [--force] [--with-config] [--no-profiles]

Init installs peer tools when missing
(prefer uv for hctl; brew/GitHub for gum).
Use --skip-deps to skip installs.

Run options:
  --module NAME     Matrix module (config default)
  --profile NAME    hctl profile
  --tech NAME       Filter by tech
  --set NAME        Filter by set
  --alias A,B       Filter by alias
  --branch NAME     Git branch for all github pipelines
                    (otherwise prompted per pipeline)
  --dry-run         Preview without POSTing
  --no-open         Do not open uiUrls
  --open            Open uiUrls anyway

Matrix options (list/add/edit/remove):
  --module NAME
  --profile NAME
  --alias NAME              add/edit/remove
  --new-alias NAME          edit: rename
  --type github|custom      add/edit (default: github)
  --trigger ID              github: webhook trigger id (fetches inputYaml);
                            custom: required webhook trigger id
  --repo NAME               github: override repo (--repo-identifier)
  --connector ID            github: override connectorRef query
  --tech NAME               add/edit (default: java)
  --set NAME                add/edit (default: shared)
  --pipeline-org ORG        add (required) / edit
  --pipeline-project NAME   add (required) / edit
  --pipeline-id ID          add (required) / edit

type=github: get-trigger → resolve inputYaml → pipeline execute.
type=custom: POST Harness custom webhook trigger.
Branch is not stored on matrix entries — prompted at run (or --branch).
Edit (CLI): only flags you pass are changed.
Edit (TUI): pick a pipeline; blank keeps the current value.

Export / import:
  Bundles matrices + redacted hctl profile stubs (host/account/org/project).
  API keys are omitted unless --include-secrets. Import merges matrices;
  existing files are skipped unless --force. Recipients set their own API key
  via hts profile init / hctl.
EOF
}

hts_cmd_init() {
  local name="" skip_deps=0
  while (( $# )); do
    case "$1" in
      --profile|--name) name="$2"; shift 2 ;;
      --skip-deps) skip_deps=1; shift ;;
      -h|--help)
        print -- "usage: hts init [--profile NAME] [--skip-deps]"
        print -- "  Installs peer deps (hctl via uv when possible, gum via brew/GitHub),"
        print -- "  writes ~/.config/hctl-tui, seeds a sample matrix, then runs hctl init."
        return 0
        ;;
      *)
        # bare profile name: hts init sandbox
        if [[ -z "$name" && "$1" != --* ]]; then
          name="$1"; shift
        else
          hts_die "unknown option: $1 (try: hts init --help)"
          return 1
        fi
        ;;
    esac
  done

  hts_path_prepend_user_bin

  if (( ! skip_deps )); then
    hts_log "ensuring dependencies…"
    hts_deps_install || {
      hts_err "dependency install incomplete — fix the errors above, or re-run with --skip-deps"
      return 1
    }
    print -- ""
  fi

  hts_log "bootstrapping hctl-tui config…"
  hts_ensure_config

  local profile_for_seed example
  profile_for_seed="${name:-default}"
  example="$(hts_matrix_path "$profile_for_seed" "$(hts_default_module)")"
  if [[ ! -f "$example" ]]; then
    /bin/mkdir -p "${example:h}"
    local src="$HTS_ROOT/matrices.example.yaml"
    if [[ -f "$src" ]]; then
      /bin/cp "$src" "$example"
    else
      /bin/cat >"$example" <<'EOF'
module: ci
entries: []
EOF
    fi
    hts_log "seeded matrix: $example (edit triggers before running for real)"
  fi

  if ! hts_have hctl; then
    hts_err "hctl is not installed (required for Harness auth)"
    hts_err "re-run: hts init   # or: uv tool install git+https://github.com/ianmatson/harness-cli.git"
    return 1
  fi

  hts_profile_init "$name"
  hts_log "done. Next: edit matrices under $HTS_MATRICES_DIR, then: hts"
}

hts_cmd_run() {
  local profile="" module="" tech="" set_="" aliases="" branch=""
  local dry_run=0 open_urls=-1

  while (( $# )); do
    case "$1" in
      --profile) profile="$2"; shift 2 ;;
      --module)  module="$2"; shift 2 ;;
      --tech)    tech="$2"; shift 2 ;;
      --set)     set_="$2"; shift 2 ;;
      --alias)   aliases="$2"; shift 2 ;;
      --branch)  branch="$2"; shift 2 ;;
      --dry-run) dry_run=1; shift ;;
      --no-open) open_urls=0; shift ;;
      --open)    open_urls=1; shift ;;
      -h|--help) hts_usage; return 0 ;;
      *) hts_die "unknown option: $1"; return 1 ;;
    esac
  done

  hts_require_deps matrix || return 1
  hts_ensure_config

  profile="$(hts_resolve_profile "$profile")"
  module="${module:-$(hts_default_module)}"

  if (( open_urls < 0 )); then
    if hts_open_urls_enabled; then open_urls=1; else open_urls=0; fi
  fi
  if (( dry_run )); then
    open_urls=0
  fi

  if (( ! dry_run )); then
    hts_require_deps run || return 1
  fi

  hts_run_matrix "$profile" "$module" "$tech" "$set_" "$aliases" "$dry_run" "$open_urls" "$branch"
}

hts_cmd_profile() {
  local sub="${1:-list}"
  if (( $# > 0 )); then
    shift
  fi
  case "$sub" in
    list) hts_profile_list "$@" ;;
    use)
      [[ -n "${1:-}" ]] || { hts_die "usage: hts profile use NAME"; return 1; }
      hts_profile_use "$1"
      ;;
    init)
      if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        print -- "usage: hts profile init [NAME]"
        print -- "  Creates/updates an hctl profile (requires hctl)."
        return 0
      fi
      local name=""
      if [[ "${1:-}" == "--name" || "${1:-}" == "--profile" ]]; then name="${2:-}"; fi
      if [[ -n "${1:-}" && "${1:-}" != "--name" && "${1:-}" != "--profile" ]]; then name="$1"; fi
      hts_profile_init "$name"
      ;;
    -h|--help)
      print -- "usage: hts profile list|use|init"
      return 0
      ;;
    *) hts_die "usage: hts profile list|use|init"; return 1 ;;
  esac
}

hts_cmd_matrix() {
  local sub="${1:-list}"
  if (( $# > 0 )); then
    shift
  fi
  if [[ "$sub" == "-h" || "$sub" == "--help" ]]; then
    print -- "usage: hts matrix list|add|edit|remove [options]"
    print -- "  see: hts help"
    return 0
  fi

  local profile="" module="" alias="" new_alias="" trigger="" tech="" set_=""
  local org="" project="" identifier="" etype="" repo="" connector=""
  local patch_type=0 patch_trigger=0 patch_tech=0 patch_set=0
  local patch_org=0 patch_project=0 patch_id=0
  local patch_repo=0 patch_connector=0

  while (( $# )); do
    case "$1" in
      --profile) profile="$2"; shift 2 ;;
      --module)  module="$2"; shift 2 ;;
      --alias)   alias="$2"; shift 2 ;;
      --new-alias) new_alias="$2"; shift 2 ;;
      --type)    etype="$2"; patch_type=1; shift 2 ;;
      --trigger) trigger="$2"; patch_trigger=1; shift 2 ;;
      --repo)    repo="$2"; patch_repo=1; shift 2 ;;
      --connector) connector="$2"; patch_connector=1; shift 2 ;;
      --tech)    tech="$2"; patch_tech=1; shift 2 ;;
      --set)     set_="$2"; patch_set=1; shift 2 ;;
      --pipeline-org) org="$2"; patch_org=1; shift 2 ;;
      --pipeline-project) project="$2"; patch_project=1; shift 2 ;;
      --pipeline-id) identifier="$2"; patch_id=1; shift 2 ;;
      --branch)
        hts_die "branch is not stored on matrix entries — use: hts run --branch NAME (or run interactively)"
        return 1
        ;;
      -h|--help)
        print -- "usage: hts matrix list|add|edit|remove [options]"
        print -- "  see: hts help"
        return 0
        ;;
      *)
        hts_die "unknown matrix option: $1 (try: hts help)"
        return 1
        ;;
    esac
  done

  hts_ensure_config
  profile="$(hts_resolve_profile "$profile")"
  module="${module:-$(hts_default_module)}"

  case "$sub" in
    list)
      hts_matrix_list "$profile" "$module"
      ;;
    add)
      [[ -n "$alias" && -n "$org" && -n "$project" && -n "$identifier" ]] \
        || { hts_die "matrix add requires --alias --pipeline-org --pipeline-project --pipeline-id"; return 1; }
      etype="${etype:l}"
      case "$etype" in
        custom|webhook|custom_webhook) etype="custom" ;;
        ""|github|execute|pipeline|*) etype="github" ;;
      esac
      if [[ -z "$trigger" ]]; then
        hts_die "matrix add requires --trigger (github webhook trigger id, or custom webhook id)"
        return 1
      fi
      tech="${tech:-java}"
      set_="${set_:-shared}"
      hts_matrix_add "$profile" "$module" "$alias" "$trigger" "$tech" "$set_" "$org" "$project" "$identifier" "$etype" "$repo" "$connector"
      ;;
    edit)
      [[ -n "$alias" ]] || { hts_die "matrix edit requires --alias"; return 1; }
      if [[ -z "$new_alias" ]] && (( !patch_type && !patch_trigger && !patch_tech && !patch_set \
            && !patch_org && !patch_project && !patch_id \
            && !patch_repo && !patch_connector )); then
        hts_die "matrix edit: pass at least one field to change (e.g. --trigger ID, --set shared)"
        return 1
      fi
      hts_matrix_get_entry_json "$profile" "$module" "$alias" >/dev/null || return 1
      HTS_MX_NEW_ALIAS="$new_alias" \
      HTS_MX_TYPE="$etype" HTS_MX_PATCH_TYPE="$patch_type" \
      HTS_MX_TRIGGER="$trigger" HTS_MX_PATCH_TRIGGER="$patch_trigger" \
      HTS_MX_TECH="$tech" HTS_MX_PATCH_TECH="$patch_tech" \
      HTS_MX_SET="$set_" HTS_MX_PATCH_SET="$patch_set" \
      HTS_MX_ORG="$org" HTS_MX_PATCH_ORG="$patch_org" \
      HTS_MX_PROJECT="$project" HTS_MX_PATCH_PROJECT="$patch_project" \
      HTS_MX_IDENTIFIER="$identifier" HTS_MX_PATCH_IDENTIFIER="$patch_id" \
      HTS_MX_REPO="$repo" HTS_MX_PATCH_REPO="$patch_repo" \
      HTS_MX_CONNECTOR="$connector" HTS_MX_PATCH_CONNECTOR="$patch_connector" \
        hts_matrix_patch "$profile" "$module" "$alias"
      ;;
    remove|rm)
      [[ -n "$alias" ]] || { hts_die "matrix remove requires --alias"; return 1; }
      hts_matrix_remove "$profile" "$module" "$alias"
      ;;
    *) hts_die "usage: hts matrix list|add|edit|remove"; return 1 ;;
  esac
}

hts_cmd_doctor() {
  local fix_deps=0
  while (( $# )); do
    case "$1" in
      --fix-deps) fix_deps=1; shift ;;
      -h|--help)
        print -- "usage: hts doctor [--fix-deps]"
        return 0
        ;;
      *) hts_die "unknown option: $1"; return 1 ;;
    esac
  done

  hts_require_deps any || true
  hts_ensure_config
  hts_path_prepend_user_bin
  print -- "hts config: $HTS_CONFIG_FILE"
  print -- "active profile: $(hts_active_profile)"
  print -- "default module: $(hts_default_module)"
  print -- "open_urls: $(hts_open_urls_enabled && print true || print false)"
  print -- ""
  print -- "Dependencies:"
  hts_deps_status
  print -- ""

  if (( fix_deps )); then
    hts_deps_install || return 1
    print -- ""
  fi

  if hts_have hctl; then
    hts_profile_doctor
  else
    hts_log "hctl not installed — run: hts init   (or hts doctor --fix-deps)"
  fi
}

hts_cmd_export() {
  local out="" profile="" include_secrets=0 include_config=1
  while (( $# )); do
    case "$1" in
      --out|-o) out="$2"; shift 2 ;;
      --profile|-p) profile="$2"; shift 2 ;;
      --all) profile=all; shift ;;
      --include-secrets) include_secrets=1; shift ;;
      --no-config) include_config=0; shift ;;
      -h|--help)
        print -- "usage: hts export [--out DIR] [--profile NAME|all] [--include-secrets] [--no-config]"
        print -- "  Writes a portable bundle: matrices + redacted hctl profile stubs."
        print -- "  Default: active profile. Use --profile all for every profile."
        print -- "  API keys are redacted unless --include-secrets."
        return 0
        ;;
      *)
        if [[ -z "$out" && "$1" != --* ]]; then
          out="$1"; shift
        else
          hts_die "unknown option: $1 (try: hts export --help)"
          return 1
        fi
        ;;
    esac
  done

  hts_require_deps matrix || return 1
  hts_ensure_config
  [[ -n "$out" ]] || out="$(hts_transfer_default_out)"
  [[ -n "$profile" ]] || profile="$(hts_active_profile)"
  hts_export_bundle "$out" "$profile" "$include_secrets" "$include_config"
}

hts_cmd_import() {
  local src="" as_profile="" force=0 import_config=0 import_profiles=1
  while (( $# )); do
    case "$1" in
      --as|--profile) as_profile="$2"; shift 2 ;;
      --force|-f) force=1; shift ;;
      --with-config) import_config=1; shift ;;
      --no-profiles) import_profiles=0; shift ;;
      -h|--help)
        print -- "usage: hts import PATH [--as NAME] [--force] [--with-config] [--no-profiles]"
        print -- "  Imports matrices (and optional hctl profile stubs) from an export bundle."
        print -- "  Existing matrix files are skipped unless --force."
        print -- "  --as NAME remaps a single-profile bundle into that profile name."
        return 0
        ;;
      *)
        if [[ -z "$src" && "$1" != --* ]]; then
          src="$1"; shift
        else
          hts_die "unknown option: $1 (try: hts import --help)"
          return 1
        fi
        ;;
    esac
  done

  [[ -n "$src" ]] || { hts_die "usage: hts import PATH [--as NAME] [--force] [--with-config] [--no-profiles]"; return 1; }
  hts_require_deps matrix || return 1
  hts_ensure_config
  hts_import_bundle "$src" "$as_profile" "$force" "$import_config" "$import_profiles"
}

main() {
  local cmd="${1:-}"
  if [[ -z "$cmd" ]]; then
    if [[ -t 0 && -t 1 ]]; then
      hts_tui_main
      return $?
    else
      hts_usage
      return 1
    fi
  fi
  shift || true
  case "$cmd" in
    init)    hts_cmd_init "$@" ;;
    run)     hts_cmd_run "$@" ;;
    profile) hts_cmd_profile "$@" ;;
    matrix)  hts_cmd_matrix "$@" ;;
    doctor)  hts_cmd_doctor "$@" ;;
    export)  hts_cmd_export "$@" ;;
    import)  hts_cmd_import "$@" ;;
    help|-h|--help) hts_usage ;;
    *)
      # Allow `hts --module ci` as shorthand for run
      if [[ "$cmd" == --* ]]; then
        hts_cmd_run "$cmd" "$@"
      else
        hts_die "unknown command: $cmd (try: hts help)"
        return 1
      fi
      ;;
  esac
}

main "$@"
